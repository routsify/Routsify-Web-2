---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { PRICE, SITE } from '@/data/site';
---

<BaseLayout
  title="Guías digitales de viaje desde 2,99 € | Routsify"
  description="Guías económicas con recomendaciones por destino desde 2,99 €, pensadas para quien quiere organizarse por su cuenta sin empezar de cero."
  canonical="/guias/"
  alternates={[
    { hreflang: 'x-default', href: `${SITE.url}/` },
    { hreflang: 'es-419', href: `${SITE.url}/latam/` },
    { hreflang: 'es-ES', href: `${SITE.url}/europa/` }
  ]}
>
  <section class="section-hero">
    <div class="grid gap-8 lg:grid-cols-[1fr_0.95fr] lg:items-center">
      <div class="flow" data-reveal>
        <p class="eyebrow">Complemento útil</p>
        <div class="kicker">
          <span class="h-2.5 w-2.5 rounded-full bg-[color:var(--accent)]"></span>
          Recomendaciones útiles por destino
        </div>
        <h1 class="max-w-4xl text-balance text-5xl leading-[0.94] text-[color:var(--text)] sm:text-6xl lg:text-[clamp(3.9rem,5.8vw,6rem)]">
          Guías digitales de recomendaciones por destino desde {PRICE.guidesFrom.toFixed(2).replace('.', ',')} €.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-[color:var(--muted)] sm:text-xl">
          Una opción accesible para quien quiere organizarse por su cuenta con una base mejor pensada que empezar desde cero.
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          <a href={SITE.whatsappUrl} class="btn-primary">Pedir catálogo por WhatsApp</a>
          <a href="/ruta-personalizada/" class="btn-secondary">Quiero una ruta a medida</a>
        </div>
      </div>

      <aside class="panel-soft rounded-[2rem] p-7" data-reveal>
        <p class="eyebrow">Qué resuelve</p>
        <div class="mt-5 grid gap-4">
          {[
            'Recomendaciones esenciales del destino',
            'Ahorro de tiempo en la investigación',
            'Idea clara de qué vale la pena priorizar',
            'Complemento para entender después la ruta personalizada'
          ].map((item) => (
            <div class="rounded-[1.2rem] border border-[rgba(35,44,34,0.08)] bg-[rgba(255,252,246,0.74)] px-4 py-3 text-sm text-[color:var(--muted)]">
              {item}
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <SectionHeading
      eyebrow="Uso práctico"
      title="La guía funciona como una ayuda concreta para viajar mejor"
      copy="No compite con la ruta personalizada. La complementa."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3" data-stagger>
      {[
        ['Destinos concretos', 'Guías pensadas por ciudad o país, con un contenido útil y compacto.'],
        ['Precio bajo', 'Desde 2,99 € como umbral de entrada y prueba de marca.'],
        ['Menos fricción', 'Ideal para usuarios que todavía no quieren contratar una planificación completa.'],
        ['Más confianza', 'Quien compra una guía puede acabar entendiendo el valor del servicio principal.'],
        ['Mantenimiento simple', 'Constantes editables y estructura modular para añadir nuevos destinos.'],
        ['Complemento comercial', 'Un recurso útil que puede abrir la puerta a la ruta personalizada cuando el viaje lo pide.']
      ].map(([title, copy], index) => (
        <article class="panel-soft lift-hover rounded-[1.5rem] p-6" data-reveal style={`--delay:${index}`}>
          <h3 class="text-2xl text-[color:var(--text)]">{title}</h3>
          <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
      <article class="panel rounded-[2rem] p-8" data-reveal>
        <p class="eyebrow">Precio visible</p>
        <div class="mt-4 flex items-end gap-3">
          <span class="text-6xl text-[color:var(--text)]">{PRICE.guidesFrom.toFixed(2).replace('.', ',')} €</span>
          <span class="pb-2 text-sm text-[color:var(--muted)]">desde</span>
        </div>
        <p class="mt-4 text-sm leading-7 text-[color:var(--muted)]">
          Si cambias el precio, hazlo en <code class="rounded bg-[rgba(35,44,34,0.06)] px-1.5 py-0.5 text-xs">{`PRICE.guidesFrom`}</code>.
        </p>
      </article>
      <article class="panel-dark rounded-[2rem] p-8" data-reveal>
        <SectionHeading
          eyebrow="CTA"
          title="Si no necesitas la ruta completa, empieza por aquí"
          copy="La guía digital da una entrada más suave al ecosistema de Routsify y permite filtrar mejor la intención."
        />
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={SITE.whatsappUrl} class="btn-primary">Quiero ver las guías por WhatsApp</a>
          <a href="/ruta-personalizada/" class="btn-secondary">Prefiero una ruta a medida</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
