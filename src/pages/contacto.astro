---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { SITE } from '@/data/site';
---

<BaseLayout
  title="Contacto | Routsify"
  description="Contacto oficial de Routsify con formulario Fillout embebido y WhatsApp como canal principal."
  canonical="/contacto/"
  alternates={[
    { hreflang: 'x-default', href: `${SITE.url}/` },
    { hreflang: 'es-419', href: `${SITE.url}/latam/` },
    { hreflang: 'es-ES', href: `${SITE.url}/europa/` }
  ]}
>
  <section class="section-tight pt-8 sm:pt-12 lg:pt-20">
    <div class="grid gap-8 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="flow">
        <p class="eyebrow">Contacto</p>
        <div class="kicker">
          <span class="h-2.5 w-2.5 rounded-full bg-[color:var(--accent)]"></span>
          WhatsApp primero · Fillout si prefieres escribirlo todo
        </div>
        <h1 class="max-w-4xl text-balance text-5xl leading-[0.94] text-[color:var(--text)] sm:text-6xl lg:text-[clamp(3.9rem,5.8vw,6rem)]">
          Cuéntanos tu viaje y te diremos por dónde empezar.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-[color:var(--muted)] sm:text-xl">
          Este es el formulario principal del sitio. Si prefieres una conversación directa, WhatsApp sigue siendo la vía más rápida.
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          <a href={SITE.whatsappUrl} class="btn-primary">Escribir por WhatsApp</a>
        </div>
      </div>

      <aside class="panel-soft rounded-[2rem] p-7" data-reveal>
        <p class="eyebrow">Datos directos</p>
        <div class="mt-5 space-y-4 text-sm text-[color:var(--muted)]">
          <p><span class="text-[color:var(--text)]">WhatsApp:</span> <a class="link-soft" href={SITE.whatsappUrl}>{SITE.whatsapp}</a></p>
          <p><span class="text-[color:var(--text)]">Email administrativo:</span> {SITE.email}</p>
          <p><span class="text-[color:var(--text)]">Dirección:</span> {SITE.address}</p>
        </div>
        <div class="mt-6 rounded-[1.35rem] border border-[rgba(35,44,34,0.08)] bg-[rgba(255,252,246,0.74)] p-5">
          <p class="eyebrow">Qué esperamos en tu mensaje</p>
          <ul class="mt-4 space-y-3 text-sm leading-7 text-[color:var(--muted)]">
            <li>Destino o tipo de viaje.</li>
            <li>Fechas aproximadas o flexibilidad.</li>
            <li>Presupuesto orientativo.</li>
            <li>Si viajas solo, en pareja o en grupo.</li>
          </ul>
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="panel rounded-[2rem] p-4 sm:p-6 lg:p-8">
      <SectionHeading
        eyebrow="Formulario Fillout"
        title="Completa el formulario embebido y seguimos por WhatsApp"
        copy="El embed mantiene el flujo de captación limpio sin depender de un backend propio."
      />
      <div class="mt-8 overflow-hidden rounded-[1.75rem] border border-[rgba(35,44,34,0.08)] bg-white">
        <iframe
          title="Formulario de contacto Routsify"
          src="https://routsify.fillout.com/t/itUeh5jZBXus"
          class="h-[1180px] w-full border-0 md:h-[1260px]"
          loading="lazy"
          allow="clipboard-read; clipboard-write"
        ></iframe>
      </div>
      <div class="mt-6 flex flex-wrap items-center gap-3">
        <a href={SITE.whatsappUrl} class="btn-primary">O hablar por WhatsApp</a>
        <span class="text-sm text-[color:var(--muted)]">Si el embed no carga, usa el enlace de WhatsApp.</span>
      </div>
    </div>
  </section>
</BaseLayout>
