---
import BaseLayout from '@/layouts/BaseLayout.astro';
import GeoSuggest from '@/components/GeoSuggest.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import {
  DESTINATION_LANES,
  FAQS,
  HOME_COMPARISON,
  HOME_CTAS,
  HOME_INCLUDES,
  HOME_MOMENTS,
  HOME_PROMISES,
  HOME_TRUST,
  PRICE,
  SITE,
  TESTIMONIALS
} from '@/data/site';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': ['TravelAgency', 'Organization'],
    '@id': `${SITE.url}/#organization`,
    name: SITE.name,
    url: SITE.url,
    description: SITE.slogan,
    email: SITE.email,
    telephone: SITE.whatsapp,
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Agencia de Viajes Online',
      postalCode: '08027',
      addressLocality: 'Barcelona',
      addressRegion: 'Barcelona',
      addressCountry: 'ES'
    },
    contactPoint: [
      {
        '@type': 'ContactPoint',
        contactType: 'customer support',
        telephone: SITE.whatsapp,
        areaServed: ['ES', 'ES-CT', 'LATAM'],
        availableLanguage: ['es']
      }
    ],
    sameAs: [SITE.instagram, SITE.tiktok]
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${SITE.url}/#website`,
    url: SITE.url,
    name: SITE.name,
    publisher: { '@id': `${SITE.url}/#organization` },
    inLanguage: 'es'
  }
];
---

<BaseLayout
  title="Routsify | Viajes personalizados a medida"
  description="Diseñamos viajes personalizados a Europa, Marruecos, Egipto y otros destinos con un enfoque premium, humano y muy claro."
  canonical="/"
  alternates={[
    { hreflang: 'x-default', href: `${SITE.url}/` },
    { hreflang: 'es-419', href: `${SITE.url}/latam/` },
    { hreflang: 'es-ES', href: `${SITE.url}/europa/` }
  ]}
  jsonLd={jsonLd}
>
  <section class="section-tight pt-8 sm:pt-12 lg:pt-20">
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr] lg:items-center">
      <div class="flow">
        <p class="eyebrow">Travel design studio</p>
        <div class="inline-flex items-center gap-2 rounded-full border border-white/10 bg-white/5 px-4 py-2 text-sm text-white/72">
          <span class="h-2 w-2 rounded-full bg-[#9fe7d5]"></span>
          Organizamos tu viaje a Europa, Marruecos y Egipto
        </div>
        <h1 class="max-w-3xl text-4xl leading-[0.95] text-white sm:text-5xl lg:text-7xl">
          Diseñamos tu viaje personalizando hasta el más mínimo detalle.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-white/72 sm:text-xl">
          No vendemos paquetes cerrados. Creamos rutas a medida según tu presupuesto, gustos, fechas, requisitos y ritmo de viaje. Te acompañamos antes y durante el viaje para que todo se sienta claro, humano y premium.
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          <a href={SITE.whatsappUrl} class="btn-primary">Hablar por WhatsApp</a>
          <a href="/guias/" class="btn-secondary">Ver guías desde 2,99 €</a>
        </div>
        <div class="flex flex-wrap gap-2 pt-4 text-sm text-white/60">
          {CORE_BENEFITS.map((item) => (
            <span class="rounded-full border border-white/10 bg-white/5 px-3 py-2">{item}</span>
          ))}
        </div>
      </div>

      <div class="relative">
        <div class="absolute -left-8 -top-8 h-28 w-28 rounded-full bg-[#9fe7d5]/15 blur-3xl"></div>
        <div class="absolute -right-6 top-12 h-24 w-24 rounded-full bg-[#f7c36d]/20 blur-3xl"></div>
        <div class="glass-strong relative overflow-hidden rounded-[2rem] p-5 shadow-glow">
          <div class="grid gap-4 sm:grid-cols-2">
            <article class="soft-card rounded-[1.5rem] p-5 sm:col-span-2">
              <div class="flex items-center justify-between gap-4">
                <div>
                  <p class="text-xs uppercase tracking-[0.24em] text-white/45">Selector inteligente</p>
                  <h2 class="mt-2 text-2xl text-white">Elige tu puerta de entrada</h2>
                </div>
                <span class="rounded-full border border-[#9fe7d5]/25 bg-[#9fe7d5]/10 px-3 py-1 text-xs font-semibold text-[#bdf1e7]">
                  Indexable
                </span>
              </div>
              <p class="mt-3 text-sm leading-7 text-white/68">
                Dos landings principales para mejorar relevancia, claridad comercial y SEO sin depender de redirecciones agresivas.
              </p>
              <div class="mt-5 grid gap-3 sm:grid-cols-2">
                {LANDING_LINKS.map((item) => (
                  <a href={item.href} class="rounded-[1.35rem] border border-white/10 bg-white/5 p-4 transition hover:-translate-y-0.5 hover:bg-white/8">
                    <p class="eyebrow">{item.eyebrow}</p>
                    <h3 class="mt-2 text-lg text-white">{item.title}</h3>
                    <p class="mt-2 text-sm leading-6 text-white/60">{item.description}</p>
                  </a>
                ))}
              </div>
            </article>

            <article class="soft-card rounded-[1.35rem] p-5">
              <p class="eyebrow">Europa / LatAm</p>
              <p class="mt-3 text-3xl text-white">Europa, Marruecos y Egipto</p>
              <p class="mt-2 text-sm leading-7 text-white/62">Los destinos clave que más repiten nuestros clientes, con rutas pensadas para ahorrar tiempo real.</p>
            </article>

            <article class="soft-card rounded-[1.35rem] p-5">
              <p class="eyebrow">Soporte</p>
              <p class="mt-3 text-3xl text-white">Antes y durante el viaje</p>
              <p class="mt-2 text-sm leading-7 text-white/62">Acompañamiento, mapas, documentos, reservas y contexto para que no viajes con dudas sueltas.</p>
            </article>
          </div>
        </div>
      </div>
    </div>
  </section>

  <GeoSuggest />

  <section class="section">
    <SectionHeading
      eyebrow="Lo que cambia"
      title="Una web para vender mejor sin parecer una agencia tradicional"
      copy="La experiencia se apoya en claridad, diseño y una estructura que ayuda a cada tipo de usuario a encontrarse rápido con la opción correcta."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      <article class="soft-card rounded-[1.5rem] p-6">
        <p class="text-sm text-white/45">01</p>
        <h3 class="mt-3 text-2xl text-white">Claridad de mensaje</h3>
        <p class="mt-3 text-sm leading-7 text-white/64">Dos landings, dos contextos y una propuesta de valor precisa para no mezclar audiencias.</p>
      </article>
      <article class="soft-card rounded-[1.5rem] p-6">
        <p class="text-sm text-white/45">02</p>
        <h3 class="mt-3 text-2xl text-white">Conversión suave</h3>
        <p class="mt-3 text-sm leading-7 text-white/64">CTA constantes, WhatsApp visible, contacto simple y guías de entrada económica.</p>
      </article>
      <article class="soft-card rounded-[1.5rem] p-6">
        <p class="text-sm text-white/45">03</p>
        <h3 class="mt-3 text-2xl text-white">SEO útil</h3>
        <p class="mt-3 text-sm leading-7 text-white/64">Arquitectura indexable, hreflang, copy específico y páginas pensadas para intención real de búsqueda.</p>
      </article>
      <article class="soft-card rounded-[1.5rem] p-6">
        <p class="text-sm text-white/45">04</p>
        <h3 class="mt-3 text-2xl text-white">Mantenimiento barato</h3>
        <p class="mt-3 text-sm leading-7 text-white/64">Astro + Tailwind, sin CMS de pago, sin base de datos y con constantes editables en un solo sitio.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="glass rounded-[2rem] p-8">
        <SectionHeading
          eyebrow="Destinos clave"
          title="Europa, Marruecos y Egipto como eje comercial"
          copy="El sitio deja claro qué vendéis y para quién, sin perder amplitud para otros destinos internacionales."
        />
        <div class="mt-8 space-y-4">
          {DESTINATIONS.map((item) => (
            <article class="rounded-[1.35rem] border border-white/10 bg-white/5 p-5">
              <h3 class="text-xl text-white">{item.name}</h3>
              <p class="mt-2 text-sm leading-7 text-white/64">{item.detail}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <article class="soft-card rounded-[2rem] p-6 sm:col-span-2">
          <p class="eyebrow">Mapa de valor</p>
          <h3 class="mt-3 text-3xl text-white">La web se siente como un estudio de diseño de viajes</h3>
          <p class="mt-3 max-w-2xl text-sm leading-7 text-white/64">
            Más editorial, más visual y mucho menos “agencia de paquetes”. Usamos mapas, rutas, tickets, timeline y bloques tipo bento para explicar mejor el servicio.
          </p>
        </article>
        <article class="soft-card rounded-[1.35rem] p-6">
          <p class="eyebrow">Prueba social</p>
          <h3 class="mt-3 text-xl text-white">Casos reales, sin inventar métricas</h3>
          <p class="mt-2 text-sm leading-7 text-white/64">Familias desde Colombia, Chile y México. Parejas. Rutas por Suiza, Italia, Barcelona y combinados por Europa.</p>
        </article>
        <article class="soft-card rounded-[1.35rem] p-6">
          <p class="eyebrow">Ruta de entrada</p>
          <h3 class="mt-3 text-xl text-white">Guías desde 2,99 €</h3>
          <p class="mt-2 text-sm leading-7 text-white/64">Una opción económica para captar usuarios que todavía no quieren una ruta completa.</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <SectionHeading
      eyebrow="Prueba social"
      title="Testimonios reales, redactados con más claridad y menos ruido"
      copy="Sin prometer resultados inventados. Solo mostrando el tipo de experiencia que ya está funcionando."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
      {TESTIMONIALS.map((item) => (
        <figure class="soft-card rounded-[1.5rem] p-6">
          <figcaption class="eyebrow">{item.name}</figcaption>
          <blockquote class="mt-4 text-sm leading-7 text-white/72">“{item.quote}”</blockquote>
        </figure>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="glass rounded-[2rem] p-8">
      <SectionHeading
        eyebrow="Siguiente paso"
        title="Empieza por la puerta que más encaje contigo"
        align="center"
        copy="Puedes cambiar de landing cuando quieras. No bloqueamos el acceso ni forzamos una redirección agresiva."
      />
      <div class="mt-8 grid gap-4 md:grid-cols-2">
        {LANDING_LINKS.map((item) => (
          <a href={item.href} class="soft-card rounded-[1.5rem] p-6 transition hover:-translate-y-0.5">
            <p class="eyebrow">{item.eyebrow}</p>
            <h3 class="mt-3 text-2xl text-white">{item.title}</h3>
            <p class="mt-2 text-sm leading-7 text-white/64">{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
