---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { DESTINATIONS, FAQS, SITE, TRUST_STATEMENTS } from '@/data/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Viajes personalizados a Europa y todo el mundo',
  provider: {
    '@type': ['TravelAgency', 'Organization'],
    name: SITE.name,
    url: SITE.url,
    email: SITE.email,
    telephone: SITE.whatsapp,
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Agencia de Viajes Online',
      postalCode: '08027',
      addressLocality: 'Barcelona',
      addressRegion: 'Barcelona',
      addressCountry: 'ES'
    }
  },
  areaServed: ['España', 'Europa']
};
---

<BaseLayout
  title="Viajes personalizados desde España y Europa | Routsify"
  description="Viajes a medida desde España y Europa para escapadas, rutas largas, viajes de pareja, familias y experiencias internacionales personalizadas."
  canonical="/europa/"
  alternates={[
    { hreflang: 'x-default', href: `${SITE.url}/` },
    { hreflang: 'es-419', href: `${SITE.url}/latam/` },
    { hreflang: 'es-ES', href: `${SITE.url}/europa/` }
  ]}
  jsonLd={jsonLd}
>
  <section class="section-hero">
    <div class="grid gap-8 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
      <div class="flow" data-reveal>
        <p class="eyebrow">España y Europa</p>
        <div class="kicker">
          <span class="h-2.5 w-2.5 rounded-full bg-[color:var(--accent)]"></span>
          Especializados en Europa, Marruecos y Egipto
        </div>
        <h1 class="max-w-4xl text-balance text-5xl leading-[0.94] text-[color:var(--text)] sm:text-6xl lg:text-[clamp(3.9rem,5.8vw,6rem)]">
          Viajes personalizados a Europa y destinos internacionales para quien quiere que el plan salga bien.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-[color:var(--muted)] sm:text-xl">
          Si vives en España o en cualquier país de Europa, diseñamos tu próximo viaje a medida dentro o fuera del continente. Hacemos que una escapada, un viaje largo o una ruta en familia se sientan bien pensados desde el principio.
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          <a href={SITE.whatsappUrl} class="btn-primary">Hablar por WhatsApp</a>
          <a href="/ruta-personalizada/" class="btn-secondary">Ver servicio</a>
        </div>
      </div>

      <aside class="panel-dark rounded-[2rem] p-7" data-reveal>
        <p class="eyebrow text-white/68">Lo que buscas ahorrar</p>
        <h2 class="mt-3 text-3xl text-white">Tiempo, dudas y malas decisiones de ruta</h2>
        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          {['Escapadas', 'Viajes largos', 'Parejas', 'Familias', 'Grupos', 'Experiencias a medida'].map((item) => (
            <span class="rounded-full border border-white/10 bg-white/6 px-4 py-2 text-sm text-white/74">{item}</span>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <SectionHeading
      eyebrow="Qué cambia aquí"
      title="La página habla de comodidad, ahorro de tiempo y diseño experto"
      copy="Lo que necesita oír el usuario europeo es que su próximo viaje se va a construir bien."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-3" data-stagger>
      {[
        ['Escapadas y city breaks', 'Propuestas ágiles y bien resueltas para aprovechar pocos días sin caer en lo genérico.'],
        ['Viajes largos', 'Cuando hay tiempo, el itinerario se construye para que cada etapa tenga sentido.'],
        ['Parejas y familias', 'Rutas con equilibrio entre ritmo, descanso, experiencias y momentos memorables.'],
        ['Múltiples destinos', 'Europa combinada con Marruecos o Egipto cuando el viaje lo pide.'],
        ['Presupuesto optimizado', 'Proponemos la mejor forma de usar el dinero sin sacrificar el valor del viaje.'],
        ['Experiencia premium', 'Un servicio serio, cercano y elegante, sin hablar como una agencia clásica de catálogo.']
      ].map(([title, copy], index) => (
        <article class="panel-soft lift-hover rounded-[1.5rem] p-6" data-reveal style={`--delay:${index}`}>
          <h3 class="text-2xl text-[color:var(--text)]">{title}</h3>
          <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="panel rounded-[2rem] p-8" data-reveal>
        <SectionHeading
          eyebrow="Destinos"
          title="Europa, Marruecos y Egipto siguen siendo el corazón de la propuesta"
          copy="Y a partir de ahí puedes abrir la puerta a más destinos internacionales."
        />
        <div class="mt-8 space-y-4">
          {DESTINATIONS.map((item) => (
            <article class="rounded-[1.4rem] border border-[rgba(35,44,34,0.08)] bg-[rgba(255,252,246,0.74)] p-5">
              <h3 class="text-xl text-[color:var(--text)]">{item.name}</h3>
              <p class="mt-2 text-sm leading-7 text-[color:var(--muted)]">{item.detail}</p>
            </article>
          ))}
        </div>
      </div>

      <div class="grid gap-4">
        <article class="panel-soft rounded-[2rem] p-7" data-reveal>
          <p class="eyebrow">Casos tipo</p>
          <div class="mt-5 grid gap-3">
            {[
              'Escapada de 10 días por Europa con buen uso del presupuesto.',
              'Pareja que quiere combinar ciudad, descanso y una ruta bien pensada.',
              'Viaje familiar con equilibrio entre ritmo, logística y disfrute.'
            ].map((item) => (
              <div class="rounded-[1.25rem] border border-[rgba(35,44,34,0.08)] bg-[rgba(255,252,246,0.74)] px-4 py-3 text-sm leading-7 text-[color:var(--muted)]">
                {item}
              </div>
            ))}
          </div>
        </article>

        <article class="panel-dark rounded-[2rem] p-7" data-reveal>
          <p class="eyebrow text-white/68">Confianza</p>
          <div class="mt-5 grid gap-3">
            {TRUST_STATEMENTS.map((item) => (
              <div class="rounded-[1.25rem] border border-white/10 bg-white/6 px-4 py-3 text-sm leading-7 text-white/74">
                {item}
              </div>
            ))}
          </div>
        </article>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="grid gap-6 lg:grid-cols-[1fr_0.95fr]">
      <article class="panel rounded-[2rem] p-8" data-reveal>
        <SectionHeading
          eyebrow="Preguntas frecuentes"
          title="Las dudas habituales también se responden aquí"
          copy="Una página que resuelve objeciones convierte mejor que una página bonita pero vacía."
        />
        <div class="mt-8 space-y-3">
          {FAQS.map((item) => (
            <details class="rounded-[1.35rem] border border-[rgba(35,44,34,0.08)] bg-[rgba(255,252,246,0.74)] p-5">
              <summary class="cursor-pointer list-none text-lg text-[color:var(--text)]">{item.q}</summary>
              <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{item.a}</p>
            </details>
          ))}
        </div>
      </article>
      <article class="panel-soft rounded-[2rem] p-8" data-reveal>
        <p class="eyebrow">CTA final</p>
        <h2 class="mt-3 text-4xl text-[color:var(--text)]">Cuéntanos el viaje que tienes en mente y lo ordenamos contigo</h2>
        <p class="mt-4 text-sm leading-7 text-[color:var(--muted)]">
          Si vives en España o en Europa, la conversación se centra en ritmo, tiempos, destinos combinados, escapadas o viajes largos.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={SITE.whatsappUrl} class="btn-primary">Pedir propuesta por WhatsApp</a>
          <a href="/guias/" class="btn-secondary">Ver guías económicas</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
