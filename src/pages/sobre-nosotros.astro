---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { SITE, TRUST_STATEMENTS, VALUES } from '@/data/site';
---

<BaseLayout
  title="Sobre Routsify | Viajes personalizados con experiencia y cercanía"
  description="Misión, valores, historia y colaboración con Grupo Star Viajes. Routsify diseña viajes personalizados con cercanía y criterio."
  canonical="/sobre-nosotros/"
  alternates={[
    { hreflang: 'x-default', href: `${SITE.url}/` },
    { hreflang: 'es-419', href: `${SITE.url}/latam/` },
    { hreflang: 'es-ES', href: `${SITE.url}/europa/` }
  ]}
>
  <section class="section-hero">
    <div class="grid gap-8 lg:grid-cols-[1.03fr_0.97fr] lg:items-center">
      <div class="flow" data-reveal>
        <p class="eyebrow">Marca</p>
        <div class="kicker">
          <span class="h-2.5 w-2.5 rounded-full bg-[color:var(--accent)]"></span>
          Una marca de viajes con criterio y cercanía
        </div>
        <h1 class="max-w-4xl text-balance text-5xl leading-[0.94] text-[color:var(--text)] sm:text-6xl lg:text-[clamp(3.9rem,5.8vw,6rem)]">
          Routsify diseña viajes personalizados con criterio, experiencia y cercanía.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-[color:var(--muted)] sm:text-xl">
          Combinamos experiencia, personalización y una forma muy clara de acompañar al cliente para que cada viaje se sienta único, útil y bien resuelto.
        </p>
      </div>
      <div class="panel-strong rounded-[2rem] p-7" data-reveal>
        <p class="eyebrow">Colaboración</p>
        <h2 class="mt-3 text-3xl text-[color:var(--text)]">Grupo Star Viajes</h2>
        <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">
          Routsify colabora con Grupo Star Viajes, grupo de gestión de agencias con más de 35 años de experiencia, para reforzar el respaldo operativo y la trayectoria comercial.
        </p>
      </div>
    </div>
  </section>

  <section class="section">
    <SectionHeading
      eyebrow="Misión"
      title="Hacer que viajar a medida sea más humano, más claro y más fácil de entender"
      copy="La web comunica confianza sin sonar rígida, y premium sin volverse distante."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2">
      <article class="panel-soft rounded-[1.5rem] p-6" data-reveal>
        <h3 class="text-2xl text-[color:var(--text)]">Experiencia</h3>
        <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">Cada viaje se construye desde el criterio, no desde el catálogo.</p>
      </article>
      <article class="panel-soft rounded-[1.5rem] p-6" data-reveal>
        <h3 class="text-2xl text-[color:var(--text)]">Cercanía</h3>
        <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">La conversación humana sigue siendo la base: escuchar, ordenar y acompañar con claridad.</p>
      </article>
    </div>
  </section>

  <section class="section">
    <SectionHeading
      eyebrow="Valores"
      title="La marca se sostiene sobre cuatro ideas simples"
      copy="Sirven para guiar el copy, el diseño y las decisiones de comunicación."
    />
    <div class="mt-10 grid gap-4 md:grid-cols-2 xl:grid-cols-4" data-stagger>
      {VALUES.map((item, index) => (
        <article class="panel-soft lift-hover rounded-[1.5rem] p-6" data-reveal style={`--delay:${index}`}>
          <h3 class="text-2xl text-[color:var(--text)]">{item.title}</h3>
          <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{item.copy}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="section">
    <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
      <div class="panel rounded-[2rem] p-8" data-reveal>
        <SectionHeading
          eyebrow="Historia"
          title="La propuesta nace para resolver una fricción muy concreta"
          copy="La gente quiere viajar bien, pero no siempre quiere construir un viaje sola."
        />
        <p class="mt-6 text-sm leading-7 text-[color:var(--muted)]">
          Routsify se presenta como esa capa experta que transforma deseos difusos en rutas bien diseñadas. Desde viajes en familia hasta rutas multicountry, la marca prioriza criterio, soporte y claridad en cada paso.
        </p>
      </div>
      <div class="panel-dark rounded-[2rem] p-8" data-reveal>
        <p class="eyebrow text-white/68">Qué transmitir</p>
        <div class="mt-5 grid gap-3">
          {TRUST_STATEMENTS.map((item) => (
            <div class="rounded-[1.2rem] border border-white/10 bg-white/6 px-4 py-3 text-sm leading-7 text-white/74">
              {item}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
