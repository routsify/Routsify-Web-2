---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { HOME_INCLUDES, HOME_MOMENTS, FAQS, PRICE, SITE } from '@/data/site';

const routePrice = PRICE.personalizedRoutePerDay.toFixed(2).replace('.', ',');
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: 'Ruta personalizada Routsify',
  brand: { '@type': 'Brand', name: SITE.name },
  seller: {
    '@type': ['TravelAgency', 'Organization'],
    name: SITE.name,
    url: SITE.url,
    email: SITE.email,
    telephone: SITE.whatsapp,
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Agencia de Viajes Online',
      postalCode: '08027',
      addressLocality: 'Barcelona',
      addressRegion: 'Barcelona',
      addressCountry: 'ES'
    }
  },
  offers: {
    '@type': 'Offer',
    priceCurrency: 'EUR',
    price: PRICE.personalizedRoutePerDay,
    availability: 'https://schema.org/InStock'
  }
};
---

<BaseLayout
  title="Ruta personalizada | Viajes a medida con Routsify"
  description="La ruta personalizada de Routsify explica qué incluye el servicio, cómo funciona, el precio por día de ruta y cómo pedir una propuesta."
  canonical="/ruta-personalizada/"
  alternates={[
    { hreflang: 'x-default', href: `${SITE.url}/` },
    { hreflang: 'es-419', href: `${SITE.url}/latam/` },
    { hreflang: 'es-ES', href: `${SITE.url}/europa/` }
  ]}
  jsonLd={jsonLd}
>
  <section class="section-hero">
    <div class="grid gap-8 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
      <div class="flow" data-reveal>
        <p class="eyebrow">Ruta personalizada</p>
        <div class="kicker">
          <span class="h-2.5 w-2.5 rounded-full bg-[color:var(--accent)]"></span>
          Ruta pensada para que el viaje tenga lógica desde el primer día
        </div>
        <h1 class="max-w-4xl text-balance text-5xl leading-[0.94] text-[color:var(--text)] sm:text-6xl lg:text-[clamp(3.9rem,5.8vw,6rem)]">
          La ruta personalizada convierte tu viaje en un plan claro, útil y bien resuelto.
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-[color:var(--muted)] sm:text-xl">
          Diseñamos una ruta a medida con estructura, criterio y soporte. Tú nos das el contexto y nosotros convertimos eso en un viaje realista, bonito y fácil de ejecutar.
        </p>
        <div class="flex flex-wrap gap-3 pt-2">
          <a href={SITE.whatsappUrl} class="btn-primary">Pedir presupuesto por WhatsApp</a>
          <a href="/faq/" class="btn-secondary">Resolver dudas</a>
        </div>
      </div>

      <aside class="panel-strong rounded-[2rem] p-7" data-reveal>
        <p class="eyebrow">Precio editable</p>
        <div class="mt-4 flex items-end gap-3">
          <span class="text-6xl text-[color:var(--text)]">{routePrice} €</span>
          <span class="pb-2 text-sm text-[color:var(--muted)]">{PRICE.personalizedRouteLabel}</span>
        </div>
        <p class="mt-4 text-sm leading-7 text-[color:var(--muted)]">
          Si este importe cambia, actualiza <code class="rounded bg-[rgba(35,44,34,0.06)] px-1.5 py-0.5 text-xs">{`PRICE.personalizedRoutePerDay`}</code> y el sitio lo reflejará en todas partes.
        </p>
        <div class="mt-6 grid gap-3">
          {[
            'Asesoría inicial',
            'Diseño de la ruta',
            'Itinerario día a día',
            'Recomendaciones de reservas',
            'Soporte antes y durante el viaje'
          ].map((item) => (
            <div class="rounded-[1.1rem] border border-[rgba(35,44,34,0.08)] bg-[rgba(255,252,246,0.74)] px-4 py-3 text-sm text-[color:var(--muted)]">
              {item}
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
      <article class="panel rounded-[2rem] p-8" data-reveal>
        <SectionHeading
          eyebrow="Qué incluye"
          title="Todo lo necesario para que la ruta no dependa de improvisar"
          copy="La página explica el servicio con una lista clara de entregables y un proceso entendible."
        />
        <div class="mt-8 grid gap-3 sm:grid-cols-2" data-stagger>
          {HOME_INCLUDES.map((item, index) => (
            <div class="rounded-[1.2rem] border border-[rgba(35,44,34,0.08)] bg-[rgba(255,252,246,0.74)] px-4 py-3 text-sm text-[color:var(--muted)]" data-reveal style={`--delay:${index}`}>
              {item}
            </div>
          ))}
        </div>
      </article>

      <article class="panel-soft rounded-[2rem] p-8" data-reveal>
        <SectionHeading
          eyebrow="Cómo funciona"
          title="Un proceso simple, humano y muy claro"
          copy="Cinco pasos para pasar de la idea difusa a una ruta lista para usar."
        />
        <ol class="mt-8 space-y-4">
          {HOME_MOMENTS.map((item, index) => (
            <li class="rounded-[1.35rem] border border-[rgba(35,44,34,0.08)] bg-[rgba(255,252,246,0.76)] px-5 py-4" data-reveal style={`--delay:${index}`}>
              <p class="text-sm uppercase tracking-[0.2em] text-[color:var(--accent)]">{String(index + 1).padStart(2, '0')}</p>
              <h3 class="mt-2 text-xl text-[color:var(--text)]">{item.title}</h3>
              <p class="mt-2 text-sm leading-7 text-[color:var(--muted)]">{item.copy}</p>
            </li>
          ))}
        </ol>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="grid gap-6 lg:grid-cols-[1.02fr_0.98fr]">
      <article class="panel-dark rounded-[2rem] p-8" data-reveal>
        <p class="eyebrow text-white/68">Casos de uso</p>
        <h2 class="mt-3 text-3xl text-white">Viajes de pareja, familia o rutas multicountry</h2>
        <div class="mt-6 grid gap-3">
          {[
            'Suiza + Italia + Barcelona en una ruta equilibrada.',
            'Viaje familiar desde Colombia con foco en comodidad y tiempos realistas.',
            'Escapada de 10 días por Europa con buen uso del presupuesto.',
            'Viaje a Marruecos o Egipto con soporte de logística y contexto.'
          ].map((item) => (
            <div class="rounded-[1.2rem] border border-white/10 bg-white/6 px-4 py-3 text-sm leading-7 text-white/74">
              {item}
            </div>
          ))}
        </div>
      </article>
      <article class="panel rounded-[2rem] p-8" data-reveal>
        <SectionHeading
          eyebrow="CTA"
          title="Cuéntanos tu idea y la convertimos en ruta"
          copy="Desde aquí el cliente entiende el valor, el proceso y el precio editable sin sensación de fricción."
        />
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={SITE.whatsappUrl} class="btn-primary">Solicitar propuesta por WhatsApp</a>
          <a href="/guias/" class="btn-secondary">Ver opción económica</a>
        </div>
      </article>
    </div>
  </section>

  <section class="section">
    <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr]">
      <article class="panel-soft rounded-[2rem] p-8" data-reveal>
        <p class="eyebrow">FAQ</p>
        <h2 class="mt-3 text-3xl text-[color:var(--text)]">Aclaramos lo importante antes de que nos escribas</h2>
        <div class="mt-8 space-y-3">
          {FAQS.slice(0, 3).map((item) => (
            <details class="rounded-[1.3rem] border border-[rgba(35,44,34,0.08)] bg-[rgba(255,252,246,0.72)] p-5">
              <summary class="cursor-pointer list-none text-lg text-[color:var(--text)]">{item.q}</summary>
              <p class="mt-3 text-sm leading-7 text-[color:var(--muted)]">{item.a}</p>
            </details>
          ))}
        </div>
      </article>
      <article class="panel rounded-[2rem] p-8" data-reveal>
        <p class="eyebrow">Último empujón</p>
        <h2 class="mt-3 text-4xl text-[color:var(--text)]">Si ya tienes destino, fechas o presupuesto, empezamos por ahí</h2>
        <p class="mt-4 text-sm leading-7 text-[color:var(--muted)]">
          El contacto por WhatsApp suele ser la vía más rápida para ordenar una propuesta. Si prefieres escribirlo con calma, también puedes usar el formulario de Fillout.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a href={SITE.whatsappUrl} class="btn-primary">Hablar por WhatsApp</a>
          <a href="/contacto/" class="btn-secondary">Ver contacto</a>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>
