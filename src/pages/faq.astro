---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { FAQS, SITE } from '@/data/site';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQS.map((item) => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: { '@type': 'Answer', text: item.a }
  }))
};
---

<BaseLayout
  title="Preguntas frecuentes | Routsify"
  description="Resolvemos las dudas más habituales sobre viajes personalizados, guías digitales, rutas a medida y contacto."
  canonical="/faq/"
  alternates={[
    { hreflang: 'x-default', href: `${SITE.url}/` },
    { hreflang: 'es-419', href: `${SITE.url}/latam/` },
    { hreflang: 'es-ES', href: `${SITE.url}/europa/` }
  ]}
  jsonLd={jsonLd}
>
  <section class="section-tight pt-12 sm:pt-16 lg:pt-22">
    <div class="flow">
      <p class="eyebrow">FAQ</p>
      <h1 class="max-w-3xl text-5xl leading-[0.95] text-white sm:text-6xl lg:text-7xl">
        Preguntas frecuentes
      </h1>
      <p class="max-w-2xl text-lg leading-8 text-white/72 sm:text-xl">
        Una página pensada para resolver objeciones y consolidar confianza antes del contacto.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="glass rounded-[2rem] p-8">
      <SectionHeading
        eyebrow="Respuestas"
        title="Lo importante, sin rodeos"
        copy="Estas preguntas están redactadas para reflejar el lenguaje comercial de la nueva web."
      />
      <div class="mt-8 space-y-3">
        {FAQS.map((item) => (
          <details class="rounded-[1.35rem] border border-white/10 bg-white/5 p-5">
            <summary class="cursor-pointer list-none text-lg text-white">{item.q}</summary>
            <p class="mt-3 text-sm leading-7 text-white/64">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
