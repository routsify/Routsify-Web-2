---
type Props = {
  eyebrow?: string;
  title: string;
  copy?: string;
  align?: 'left' | 'center';
};

const { eyebrow, title, copy, align = 'left' } = Astro.props as Props;
---

<div class={align === 'center' ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl'}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-3 text-3xl leading-tight text-white sm:text-4xl">{title}</h2>
  {copy && <p class="mt-4 text-base leading-7 text-white/68 sm:text-lg">{copy}</p>}
</div>
