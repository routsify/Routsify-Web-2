---
type Props = {
  eyebrow?: string;
  title: string;
  copy?: string;
  align?: 'left' | 'center';
};

const { eyebrow, title, copy, align = 'left' } = Astro.props as Props;
---

<div class={align === 'center' ? 'mx-auto max-w-3xl text-center' : 'max-w-3xl'} data-reveal>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2 class="mt-3 text-3xl leading-[1.02] text-balance text-[color:var(--text)] sm:text-4xl lg:text-5xl">{title}</h2>
  {copy && <p class="mt-4 text-base leading-7 text-[color:var(--muted)] sm:text-lg">{copy}</p>}
</div>
