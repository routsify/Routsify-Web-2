---
import { NAV, SITE } from '@/data/site';

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-[rgba(35,44,34,0.08)] bg-[rgba(247,242,234,0.82)] backdrop-blur-2xl">
  <div class="section-tight !py-4">
    <div class="flex items-center justify-between gap-4 rounded-[1.6rem] border border-[rgba(35,44,34,0.08)] bg-[rgba(255,252,246,0.78)] px-4 py-3 shadow-[0_14px_34px_rgba(35,44,34,0.05)] sm:px-5">
      <a href="/" class="flex items-center gap-3">
        <span class="flex h-11 w-11 items-center justify-center rounded-full border border-[rgba(35,44,34,0.08)] bg-white">
          <img src="/logo.svg" alt={`${SITE.name} logo`} class="h-7 w-7 object-contain" />
        </span>
        <span class="leading-tight">
          <span class="block text-[0.95rem] font-semibold tracking-tight text-[color:var(--text)]">{SITE.name}</span>
          <span class="block text-[0.68rem] uppercase tracking-[0.24em] text-[color:var(--muted)]">Viajes personalizados</span>
        </span>
      </a>

      <nav class="hidden items-center gap-1 xl:flex" aria-label="Navegación principal">
        {NAV.map((item) => {
          const active = pathname === item.href;
          return (
            <a
              href={item.href}
              class={`rounded-full px-3.5 py-2 text-sm font-semibold transition ${
                active
                  ? 'bg-[rgba(73,104,75,0.12)] text-[color:var(--accent)] ring-1 ring-[rgba(73,104,75,0.14)]'
                  : 'text-[color:var(--muted)] hover:bg-[rgba(35,44,34,0.05)] hover:text-[color:var(--text)]'
              }`}
            >
              {item.label}
            </a>
          );
        })}
      </nav>

      <div class="flex items-center gap-3">
        <a href={SITE.whatsappUrl} class="btn-secondary hidden sm:inline-flex">WhatsApp</a>
        <a href={SITE.whatsappUrl} class="btn-primary">Escríbenos por WhatsApp</a>
      </div>
    </div>

    <nav class="mt-3 flex gap-2 overflow-x-auto pb-1 xl:hidden" aria-label="Navegación secundaria">
      {NAV.map((item) => {
        const active = pathname === item.href;
        return (
          <a
            href={item.href}
            class={`whitespace-nowrap rounded-full px-3.5 py-2 text-sm font-semibold transition ${
              active
                ? 'bg-[rgba(73,104,75,0.12)] text-[color:var(--accent)] ring-1 ring-[rgba(73,104,75,0.14)]'
                : 'border border-[rgba(35,44,34,0.08)] bg-[rgba(255,252,246,0.72)] text-[color:var(--muted)]'
            }`}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>
