---
const links = [
  { href: '/latam/', label: 'Ir a LatAm' },
  { href: '/europa/', label: 'Ir a Europa' }
];
---

<section class="section-tight">
  <div
    id="geo-suggest"
    class="panel-strong hidden rounded-[2rem] px-5 py-5 sm:px-6"
    data-latam-href="/latam/"
    data-europa-href="/europa/"
    data-reveal
  >
    <div class="flex flex-col gap-4 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-2xl">
        <p class="eyebrow">Punto de partida</p>
        <h2 class="mt-3 text-2xl text-[color:var(--text)] sm:text-3xl">Parece que te encaja mejor una de estas dos rutas de entrada</h2>
        <p id="geo-copy" class="mt-3 text-sm leading-7 text-[color:var(--muted)]">
          Te proponemos el camino más útil según tu idioma o zona horaria, pero puedes cambiarlo cuando quieras.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        {links.map((link) => (
          <a href={link.href} class="btn-secondary">{link.label}</a>
        ))}
      </div>
    </div>

    <script is:inline>
      (() => {
        const el = document.getElementById('geo-suggest');
        if (!el) return;
        const dismissed = localStorage.getItem('routsify-route-choice-dismissed');
        if (dismissed === '1') return;

        const lang = (navigator.language || '').toLowerCase();
        const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone || '';
        const latamMatch =
          lang.includes('es-419') ||
          (/^(es|pt)-/.test(lang) && !lang.includes('es-es')) ||
          timezone.startsWith('America/');
        const europaMatch = lang.includes('es-es') || timezone.startsWith('Europe/');
        const copy = document.getElementById('geo-copy');

        if (latamMatch || europaMatch) {
          el.classList.remove('hidden');
          if (copy) {
            copy.textContent = latamMatch
              ? 'Por tu idioma o zona horaria, quizá te resulte más útil empezar por la ruta pensada para Latinoamérica y otros continentes.'
              : 'Por tu idioma o zona horaria, quizá te resulte más útil empezar por la ruta pensada para España y Europa.';
          }
        }

        el.querySelectorAll('a').forEach((anchor) => {
          anchor.addEventListener('click', () => localStorage.setItem('routsify-route-choice-dismissed', '1'));
        });
      })();
    </script>
  </div>
</section>
